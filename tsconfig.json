{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "types": ["bun-types"],
    "noEmit": true,
    "paths": {
      "@kumacode/core": ["./packages/core/src/index.ts"],
      "@kumacode/core/*": ["./packages/core/src/*"],
      "@kumacode/tui": ["./packages/tui/src/index.ts"],
      "@kumacode/tui/*": ["./packages/tui/src/*"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
