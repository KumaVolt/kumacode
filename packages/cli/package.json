{
  "name": "@kumacode/cli",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "kumacode": "src/index.ts"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun --compile",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@kumacode/core": "workspace:*",
    "@kumacode/tui": "workspace:*",
    "commander": "^13.1.0",
    "ink": "^5.1.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "bun-types": "latest",
    "@types/react": "^18.3.0"
  }
}
